# Forme Haus — example environment variables
# Copy to .env and fill in real values. NEVER commit .env.
#
# For Oxygen production/preview, set these in:
#   Shopify admin → Hydrogen → Storefront → Environments and variables

# ─── Hydrogen / Shopify ────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
PUBLIC_STOREFRONT_API_TOKEN=
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=your-shop.myshopify.com
PUBLIC_STOREFRONT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
PUBLIC_CHECKOUT_DOMAIN=
SHOP_ID=

# ─── Backend API (if used) ─────────────────────────────────────
API_BASE_URL=
API_ACCESS_TOKEN=

# ─── Tap Payments ──────────────────────────────────────────────
# Test keys: sk_test_… / pk_test_…   Live keys: sk_live_… / pk_live_…
# Set live keys in Shopify Oxygen environment variables — NEVER commit them here.
TAP_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAP_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAP_API_URL=https://api.tap.company/v2
# Optional: your Tap merchant ID (from Tap dashboard → Account → Merchant ID)
TAP_MERCHANT_ID=
# From Tap dashboard → Developers → Webhooks. Without it, the
# webhook accepts unsigned requests and logs a warning.
TAP_WEBHOOK_SECRET=

# ─── Resend (transactional email) ─────────────────────────────
# Get a free key at resend.com → API Keys. Then add & verify the
# domain "formehaus.me" under Resend → Domains so emails can be
# sent from orders@formehaus.me. Free tier: 3,000 emails/month.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Shopify Admin API ─────────────────────────────────────────
# Required for creating orders in Shopify admin after Tap payment succeeds.
# Create a custom app: Shopify admin → Settings → Apps → Develop apps
# Scopes needed: write_orders, read_customers
# Then install the app and copy the Admin API access token here.
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google SSO ────────────────────────────────────────────────
# OAuth 2.0 client ID from Google Cloud → APIs & Services → Credentials.
# Authorized JavaScript origins must include your storefront URL.
PUBLIC_GOOGLE_CLIENT_ID=
