# Shopify Storefront API
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_STOREFRONT_ID=your-storefront-id
PUBLIC_STOREFRONT_API_TOKEN=your-public-storefront-api-token
PRIVATE_STOREFRONT_API_TOKEN=your-private-storefront-api-token
PUBLIC_CHECKOUT_DOMAIN=checkout.your-store.com

# Shopify Customer Account API
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-customer-account-api-client-id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/your-shop-id/account/customer/api/unstable

# Session
SESSION_SECRET=replace-with-long-random-string

# Google Sign-In (OAuth 2.0 Web Client ID from Google Cloud Console)
PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Tap Payments (dashboard.tap.company → API Keys)
# Use sk_test_... for sandbox, sk_live_... for production.
# Same API URL works for both — the key prefix determines mode.
TAP_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TAP_SECRET_KEY
TAP_API_URL=https://api.tap.company/v2
