# ─── Shopify Storefront ───────────────────────────────────────────────────────
SESSION_SECRET=your-session-secret-here
PUBLIC_STOREFRONT_API_TOKEN=your-public-storefront-token
PRIVATE_STOREFRONT_API_TOKEN=your-private-storefront-token
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_STOREFRONT_ID=your-storefront-id
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-customer-account-api-client-id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/authentication/your-shop-id/oauth
PUBLIC_CHECKOUT_DOMAIN=your-store.myshopify.com
SHOP_ID=your-shop-id

# ─── Internal API ─────────────────────────────────────────────────────────────
API_BASE_URL=https://your-api.example.com
API_ACCESS_TOKEN=your-api-access-token

# ─── Tap Payments ─────────────────────────────────────────────────────────────
TAP_SECRET_KEY=sk_live_your-tap-secret-key
TAP_PUBLIC_KEY=pk_live_your-tap-public-key
TAP_MERCHANT_ID=your-merchant-id
TAP_API_URL=https://api.tap.company/v2

# ─── Google SSO (OAuth 2.0) ───────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorised redirect URI: https://yourdomain.com/account/google-callback
#
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET come from your OAuth 2.0 client.
# GOOGLE_SSO_SECRET is a random secret you generate — it is used to derive
# deterministic passwords for Google-authenticated customers so they can be
# stored in Shopify. Use a strong random string (e.g. openssl rand -hex 32).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_SSO_SECRET=replace-with-a-strong-random-secret-openssl-rand-hex-32
